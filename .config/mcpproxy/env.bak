# mcpproxy secrets / env  —  ШАБЛОН
#
# Реальный файл живёт ВНЕ git: ~/.config/mcpproxy/env
#   cp .config/mcpproxy/env.example ~/.config/mcpproxy/env   (разовый шаг)
# launchd-плист сорсит его (set -a; . ~/.config/mcpproxy/env) перед запуском прокси.
#
# СИНТАКСИС ССЫЛОК В config.json (mcpproxy-go, Spec секрет-резолвер):
#   ТИПИЗИРОВАННЫЕ рефы — ${env:VAR} (из этого файла) или ${keyring:VAR} (из OS keyring).
#   Голый ${VAR} НЕ раскрывается (регекс требует ${type:name}).
#   Альтернатива env-файлу — положить секрет в keyring: `mcpproxy secrets set VAR`
#   и в config.json писать ${keyring:VAR}; тогда этот файл не нужен для данного ключа.

# --- godot (config: env GODOT_PATH) ---
GODOT_PATH=/Applications/Godot.app/Contents/MacOS/Godot

# --- mongodb инстансы (config: env MDB_MCP_CONNECTION_STRING ← ${env:SALOTECH_MONGODB_SISA_URI}) ---
SALOTECH_MONGODB_SISA_URI='mongodb://agent-watcher:5lCjivwbfUdwBmQlQskseeBiOkz8A0cu@mongodb-sisa.mp.us-east-2.k8s.int.avs.io:27017/agent-watcher?replicaSet=freshdesk&authSource=admin&readpreference=nearest'
# SALOTECH_MONGODB_OTHER_URI=mongodb://...

# --- freshdesk инстансы (config: env FRESHDESK_API_KEY / FRESHDESK_DOMAIN) ---
SALOTECH_FRESHDESK_API_KEY=
SALOTECH_FRESHDESK_DOMAIN=yourcompany.freshdesk.com
# SALOTECH_FRESHDESK_OTHER_API_KEY=
# SALOTECH_FRESHDESK_OTHER_DOMAIN=other.freshdesk.com

# slack / atlassian (salotech-*) токенов тут НЕ держим:
# OAuth делает mcp-remote, кэш в ~/.mcp-auth (вне git).

# --- shared research MCP (config: header Authorization Bearer ${env:EXA_API_KEY}) ---
EXA_API_KEY=
# context7 / grep-app — без токена (публичные HTTP MCP).
