# mcp-proxy secrets / env  —  ШАБЛОН
#
# Реальный файл живёт ВНЕ git: ~/.config/mcp-proxy/env
#   cp .config/mcp-proxy/env.example ~/.config/mcp-proxy/env   (разовый шаг)
# launchd-плист сорсит его (set -a; . ~/.config/mcp-proxy/env) перед запуском прокси,
# config.json подставляет ${VAR} через --expand-env.
#
# КОНВЕНЦИЯ МУЛЬТИ-ИНСТАНСА:
#   Канонический env-var, который читает сам MCP (MDB_MCP_CONNECTION_STRING,
#   FRESHDESK_API_KEY, …), задаётся PER-SERVER в config.json и тянет значение из
#   ИНСТАНС-УНИКАЛЬНОГО плейсхолдера <ИМЯ_ИНСТАНСА>_<CRED>, объявленного здесь.
#   Так несколько инстансов одного типа не перетирают друг друга.
#   Добавить инстанс #2: скопировать блок сервера в config.json с новым именем +
#   новым ${VAR}, и завести этот ${VAR} тут.

# --- godot ---
GODOT_PATH=/Applications/Godot.app/Contents/MacOS/Godot

# --- mongodb инстансы (config: env MDB_MCP_CONNECTION_STRING) ---
SALOTECH_MONGODB_SISA_URI=mongodb://user:pass@host:27017/db
# SALOTECH_MONGODB_OTHER_URI=mongodb://...

# --- freshdesk инстансы (config: env FRESHDESK_API_KEY / FRESHDESK_DOMAIN) ---
SALOTECH_FRESHDESK_API_KEY=
SALOTECH_FRESHDESK_DOMAIN=yourcompany.freshdesk.com
# SALOTECH_FRESHDESK_OTHER_API_KEY=
# SALOTECH_FRESHDESK_OTHER_DOMAIN=other.freshdesk.com

# slack / atlassian (salotech-*) токенов тут НЕ держим:
# OAuth делает mcp-remote, кэш в ~/.mcp-auth (вне git).

# --- shared research MCP для non-OMO клиентов ---
# OMO/OpenCode сам инжектит websearch/context7/grep_app; эти значения нужны,
# только если non-OMO контекст идёт через mcp-proxy shared-* серверы.
EXA_API_KEY=
# CONTEXT7_API_KEY=
