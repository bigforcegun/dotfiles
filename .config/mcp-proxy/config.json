{
  "mcpProxy": {
    "baseURL": "http://localhost:9090",
    "addr": ":9090",
    "name": "mcp-proxy",
    "type": "streamable-http",
    "options": {
      "logEnabled": true,
      "panicIfInvalid": false
    }
  },
  "mcpServers": {
    "semble": {
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "--from",
        "semble[mcp]",
        "semble"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "transportType": "streamable-http"
    },
    "git-grep-app": {
      "url": "https://mcp.grep.app",
      "transportType": "streamable-http"
    },
    "websearch-exa": {
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
      "transportType": "streamable-http",
      "headers": {
        "Authorization": "Bearer ${EXA_API_KEY}"
      }
    },
    "salotech-mongodb-sisa": {
      "command": "npx",
      "args": [
        "-y",
        "mongodb-mcp-server"
      ],
      "env": {
        "MDB_MCP_CONNECTION_STRING": "${SALOTECH_MONGODB_SISA_URI}"
      }
    },
    "salotech-freshdesk": {
      "command": "uvx",
      "args": [
        "freshdesk-mcp"
      ],
      "env": {
        "FRESHDESK_API_KEY": "${SALOTECH_FRESHDESK_API_KEY}",
        "FRESHDESK_DOMAIN": "${SALOTECH_FRESHDESK_DOMAIN}"
      }
    },
    "godot": {
      "command": "npx",
      "args": [
        "@coding-solo/godot-mcp"
      ],
      "env": {
        "GODOT_PATH": "${GODOT_PATH}"
      }
    },
    "salotech-slack": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.slack.com/mcp"
      ]
    },
    "salotech-atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp"
      ]
    }
  }
}