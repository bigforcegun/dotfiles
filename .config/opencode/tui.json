{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "gruvbox",
  "diff_style": "auto",
  "plugin": [
    "oh-my-openagent@4.16.2",
    "/Users/bigforcegun/.config/opencode/plugins/chat-pulse-line/tui.js",
    "/Users/bigforcegun/.config/opencode/plugins/session-cycle/tui.js",
    "@slkiser/opencode-quota@3.11.1",
    "opencode-subagent-statusline@1.2.0",
    "@ishaksebsib/opencode-tree@0.4.2"
  ],
  "keybinds": {
    "input_submit": "ctrl+return, ctrl+s",
    "input_newline": "return,shift+return",
