{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 3,
    "max_members": 6,
    "tmux_visualization": false
  },
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.6-terra-fast",
      "variant": "high"
    },
    "hephaestus": {
      "model": "openai/gpt-5.6-terra-fast",
      "variant": "high"
    },
    "oracle": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.6-luna-fast",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.6-luna",
          "variant": "low",
          "reasoningEffort": "low"
        }
      ]
    },
    "explore": {
      "model": "openai/gpt-5.6-luna-fast",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.6-luna",
          "variant": "low",
          "reasoningEffort": "low"
        }
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.6-sol-fast",
      "variant": "high"
    },
    "prometheus": {
      "model": "openai/gpt-5.6-sol-fast",
      "variant": "high"
    },
    "metis": {
      "model": "openai/gpt-5.6-sol-fast",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.6-sol-fast",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "openai/gpt-5.6-terra-fast",
      "variant": "high"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.6-luna-fast",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.6-terra-fast",
      "variant": "high"
    },
    "artistry": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high"
    },
    "quick": {
      "model": "openai/gpt-5.6-luna-fast",
      "variant": "medium",
      "reasoningEffort": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.6-luna",
          "variant": "medium",
          "reasoningEffort": "medium"
        }
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.6-terra-fast",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.6-terra-fast",
      "variant": "high",
      "fallback_models": [
        {
          "model": "openai/gpt-5.6-sol",
          "variant": "high"
        }
      ]
    },
    "writing": {
      "model": "openai/gpt-5.6-luna-fast",
      "variant": "medium",
      "reasoningEffort": "medium"
    }
  }
}