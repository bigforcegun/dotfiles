{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "share": "manual",
  "logLevel": "INFO",
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "server": {
    "port": 8896,
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama MAC AIR M2",
      "options": {
        "baseURL": "http://192.168.8.235:11434/v1"
      },
      "models": {
        "gemma3n:e4b": {
          "name": "gemma3n"
        },
        "lfm2.5-thinking:latest": {
          "name": "lfm2.5-thinking"
        },
        "codegemma:7b": {
          "name": "codegemma-7b"
        },
        "codegemma:2b": {
          "name": "codegemma-2b"
        },
        "hf.co/unsloth/Phi-4-mini-instruct-GGUF:latest": {
          "name": "phi-4-mini-instruct"
        },
        "qwen2.5-coder:7b-instruct": {
          "name": "qwen2.5-coder-7b-instruct"
        }
      }
    }
  },
  "instructions": [
    "~/.config/opencode/instructions/agent-identity.md",
    "~/.config/opencode/instructions/common.md",
    "~/.config/opencode/instructions/communication.md",
    "~/.config/opencode/instructions/opencode.md",
    "~/.config/opencode/instructions/git.md"
  ],
  "command": {
    "agent-install-hooks2": {
      "description": "Install repository Git hooks",
      "template": "Run `./scripts/install-hooks.sh` from the project root and report the resulting local Git config values."
    }
  },
  "permission": {
    "*": "allow",
    "external_directory": "ask",
    "doom_loop": "ask",
    "edit": {
      "*": "allow",
      "opencode.json": "deny",
      "opencode.json.bak": "deny",
      ".git/**": "deny",
      ".gitconfig": "deny",
      ".gitmessage": "deny",
      ".githooks/**": "deny",
      ".gitignore": "deny",
      ".gitattributes": "deny",
      ".gitmodules": "deny",
      ".opencode/**": "deny",
      "~/.config/opencode/**": "deny"
    }
  },
  "plugin": [
    "oh-my-openagent@latest",
    "@slkiser/opencode-quota@latest",
    "@ramtinj95/opencode-tokenscope@latest"
  ]
}